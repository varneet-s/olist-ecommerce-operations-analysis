    <worksheet name='H3-GMV Pareto Distribution'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Menlo'>GMV Pareto Distribution</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='MASTER (Olist_Business_Analysis)' name='federated.1eb3pt80iceddq1d8f98v11ienj2' />
          </datasources>
          <datasource-dependencies datasource='federated.1eb3pt80iceddq1d8f98v11ienj2'>
            <column caption='% of Sellers' datatype='real' default-format='p0%' name='[Calculation_6706748965249031]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='INDEX() / SIZE()'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='True GMV' datatype='real' default-format='p0.0%' name='[Calculation_6706748970110984]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{FIXED [order_id], [product_id], [seller_id] : MAX([price])}' />
            </column>
            <column caption='Top 20% of Sellers' datatype='boolean' name='[Calculation_6706748981628938]' role='measure' type='nominal'>
              <calculation class='tableau' formula='[Calculation_6706748965249031] &lt;= 0.20'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Top 20% Sellers GMV' datatype='real' name='[Calculation_6706748984356875]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Calculation_6706748981628938] THEN SUM([Calculation_6706748970110984]) END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Concentration Ratio' datatype='real' default-format='p0.00%' name='[Calculation_6706748985413644]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='WINDOW_SUM([Calculation_6706748984356875]) / WINDOW_SUM(SUM([Calculation_6706748970110984]))'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Seller Count Rank' datatype='integer' name='[Calculation_6706748993089549]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='INDEX()'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column-instance column='[seller_id]' derivation='None' name='[none:seller_id:nk]' pivot='key' type='nominal' />
            <column caption='Order Id' datatype='string' name='[order_id]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_6706748970110984]' derivation='Sum' name='[pcto:cum:sum:Calculation_6706748970110984:qk:20]' pivot='key' type='quantitative'>
              <table-calc aggregation='Sum' ordering-type='Field' type='CumTotal'>
                <order field='[federated.1eb3pt80iceddq1d8f98v11ienj2].[seller_id]' />
                <sort direction='DESC' using='[federated.1eb3pt80iceddq1d8f98v11ienj2].[sum:Calculation_6706748970110984:qk]' />
              </table-calc>
              <table-calc ordering-type='Field' type='PctTotal'>
                <order field='[federated.1eb3pt80iceddq1d8f98v11ienj2].[none:seller_id:nk]' />
                <sort direction='DESC' using='[federated.1eb3pt80iceddq1d8f98v11ienj2].[sum:Calculation_6706748970110984:qk]' />
              </table-calc>
            </column-instance>
            <column caption='Price' datatype='real' name='[price]' role='measure' type='quantitative' />
            <column caption='Product Id' datatype='string' name='[product_id]' role='dimension' type='nominal' />
            <column caption='Seller Id' datatype='string' name='[seller_id]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_6706748970110984]' derivation='Sum' name='[sum:Calculation_6706748970110984:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_6706748965249031]' derivation='User' name='[usr:Calculation_6706748965249031:qk:6]' pivot='key' type='quantitative'>
